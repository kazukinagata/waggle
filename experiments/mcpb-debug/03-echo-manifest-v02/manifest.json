{
  "manifest_version": "0.2",
  "name": "mcpb-debug-echo-manifest-v02",
  "display_name": "MCPB Debug Echo Manifest V02",
  "version": "0.0.1",
  "description": "Same as 01-echo-baseline but with manifest_version 0.2 (matching sh-mcp-auth-gateway). Tests whether manifest_version is the trigger for the Cowork Live Artifact 400.",
  "author": {
    "name": "Kazuki Nagata"
  },
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/index.js"]
    }
  },
  "tools": [
    {
      "name": "echo_test",
      "description": "Echo back the input string."
    }
  ],
  "keywords": ["debug", "echo", "mcpb", "waggle"],
  "license": "MIT",
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"]
  }
}
